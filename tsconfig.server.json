{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"]
}
